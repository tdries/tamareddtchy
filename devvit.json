{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "blendersville",
  "permissions": {
    "reddit": {
      "scope": "moderator"
    },
    "redis": true
  },
  "post": {
    "dir": "webroot",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create a Blendersville nursery",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/create-post"
      }
    ]
  },
  "dev": {
    "subreddit": "blendersville_dev"
  }
}