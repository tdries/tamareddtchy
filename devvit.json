{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "tamareddtchy",
  "permissions": {
    "reddit": { "scope": "moderator" },
    "redis": true
  },
  "post": {
    "dir": "webroot",
    "entrypoint": "index.html",
    "height": "tall"
  },
  "server": {
    "dir": "src/server",
    "entrypoint": "index.ts"
  },
  "menu": {
    "items": [
      {
        "label": "Create a Tamareddtchy nursery",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/create-post"
      }
    ]
  }
}
